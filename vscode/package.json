{
  "name": "bnscript",
  "displayName": "BN Script",
  "description": "BN Script language support with syntax highlighting and .bn file association.",
  "version": "0.1.0-alpha.0",
  "publisher": "bnscript-dev",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sayedrisat/bnscript.git"
  },
  "license": "MIT",
  "icon": "assets/icon.png",
  "files": [
    "README.md",
    "LICENSE",
    "package.json",
    "bnscript.tmLanguage.json",
    "language-configuration.json",
    "assets/icon.png",
    "assets/icon.svg",
    "samples/demo.bn"
  ],
  "contributes": {
    "languages": [
      {
        "id": "bnscript",
        "aliases": [
          "BN Script",
          "bnscript"
        ],
        "extensions": [
          ".bn"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "bnscript",
        "scopeName": "source.bnscript",
        "path": "./bnscript.tmLanguage.json"
      }
    ]
  }
}
