{
  "name": "bnscript",
  "displayName": "BN Script",
  "description": "BN Script language support with syntax highlighting, diagnostics, autocomplete, hover docs, commands, and .bn file association.",
  "version": "0.1.0-alpha.0",
  "publisher": "bnscript-dev",
  "main": "./src/extension.js",
  "activationEvents": [
    "onLanguage:bnscript",
    "onCommand:bnscript.checkCurrentFile",
    "onCommand:bnscript.buildCurrentFile",
    "onCommand:bnscript.runCurrentFile"
  ],
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sayedrisat/bnscript.git"
  },
  "license": "MIT",
  "icon": "assets/icon.png",
  "files": [
    "README.md",
    "LICENSE",
    "package.json",
    "bnscript.tmLanguage.json",
    "language-configuration.json",
    "src/commands.js",
    "src/diagnostics.js",
    "src/extension.js",
    "src/keywords.js",
    "assets/icon.png",
    "assets/icon.svg",
    "samples/demo.bn"
  ],
  "contributes": {
    "languages": [
      {
        "id": "bnscript",
        "aliases": [
          "BN Script",
          "bnscript"
        ],
        "extensions": [
          ".bn"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "bnscript",
        "scopeName": "source.bnscript",
        "path": "./bnscript.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "bnscript.checkCurrentFile",
        "title": "BN Script: Check Current File",
        "category": "BN Script"
      },
      {
        "command": "bnscript.buildCurrentFile",
        "title": "BN Script: Build Current File",
        "category": "BN Script"
      },
      {
        "command": "bnscript.runCurrentFile",
        "title": "BN Script: Run Current File",
        "category": "BN Script"
      }
    ],
    "configuration": {
      "title": "BN Script",
      "properties": {
        "bnscript.cliPath": {
          "type": "string",
          "default": "",
          "scope": "resource",
          "markdownDescription": "Absolute path to the BN Script CLI file (`src/cli.js`) for fresh workspaces. Example: `C:\\\\Users\\\\Lenovo\\\\Desktop\\\\Vs files\\\\bnscript\\\\src\\\\cli.js`."
        }
      }
    }
  }
}
